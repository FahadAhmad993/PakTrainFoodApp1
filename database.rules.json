{
  "rules": {
    "Orders": {
      "$orderId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "Users": {
      "Passenger": {
        "$uid": {
          ".read": "auth != null && auth.uid == $uid",
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    }
  }
}
