<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp">

    <!-- 🔹 Full Card Layout -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:background="@drawable/card_bg">

        <ImageView
            android:id="@+id/imgFood"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/splash" />

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chicken Biryani"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delicious spicy biryani"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtRestName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="By Qamer Foods"
                android:textSize="13sp"
                android:textColor="@color/gray" />

            <TextView
                android:id="@+id/txtPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs. 250"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="4dp" />

            <!-- Buttons Row same as before -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">

                <Button
                    android:id="@+id/btnAddCart"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Add to Cart"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:backgroundTint="@color/teal_700"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/btnBuyNow"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Buy Now"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/teal_700"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">

                <Button
                    android:id="@+id/btnCancelOrder"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Cancel Order"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:backgroundTint="@color/pink"
                    android:textColor="@android:color/white"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnAcceptOrder"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Accept Order"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:backgroundTint="@color/teal_700"
                    android:textColor="@android:color/white"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnDeliveredOrder"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Delivered To"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:backgroundTint="@color/teal_500"
                    android:textColor="@android:color/white"
                    android:visibility="gone" />
                <Button
                    android:id="@+id/btnDeleteOrder"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:text="Delete"
                    android:textSize="12sp"
                    android:padding="4dp"
                    android:backgroundTint="@color/red"
                    android:textColor="@android:color/white"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 🟢 Badge overlay on top-right -->
    <TextView
        android:id="@+id/txtStatusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accepted"
        android:textStyle="bold"
        android:textSize="12sp"
        android:padding="6dp"
        android:background="@drawable/bg_badge_green"
        android:textColor="@android:color/white"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:visibility="gone" />
    <TextView
        android:id="@+id/txtStatuBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Canceled"
        android:textStyle="bold"
        android:textSize="12sp"
        android:padding="6dp"
        android:background="@drawable/bg_badge_red"
        android:textColor="@android:color/white"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:visibility="gone" />

</FrameLayout>
