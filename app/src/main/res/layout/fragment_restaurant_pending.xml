<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    tools:context=".ui.main.Restaurant.RestaurantPendingFragment"
    android:background="@android:color/white">

    <!-- Pending Icon -->
    <ImageView
        android:id="@+id/img_pending_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_pending"
        android:contentDescription="Pending Icon"
        app:tint="#F57C00" />

    <!-- Space -->
    <View
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_pending_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Request Under Review"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#000000" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_pending_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your restaurant registration request is pending review.\nIt will be completed within 24 hours.\n\nPlease stay tuned — thanks for waiting!"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textColor="#555555"
        android:paddingTop="12dp" />

</LinearLayout>
