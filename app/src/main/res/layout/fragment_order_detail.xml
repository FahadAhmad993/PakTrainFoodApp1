<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F6F6F6">

    <!-- TOP MAP (40% SCREEN HEIGHT APPROX) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4">

        <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Gradient overlay for pro look -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/map_gradient_overlay" />

        <!-- Title on map -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Order Tracking"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="20sp"
            android:layout_margin="16dp" />
    </FrameLayout>

    <!-- BOTTOM CONTENT (60%) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6"
        android:padding="16dp">

        <!-- IMPORTANT: ONLY ONE CHILD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ETA CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:padding="16dp"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/txtCurrentStation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Station:"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000" />
                <TextView
                    android:id="@+id/txtEta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estimated Time: --"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#000" />
            </LinearLayout>

            <!-- FOOD INFO CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:padding="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtName"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Food Name"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/txtPrice"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Rs 0"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtDesc"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="Description"
                    android:textSize="14sp"
                    android:paddingTop="8dp" />
            </LinearLayout>

            <!-- TRAIN INFO CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:padding="16dp"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTrainName"
                    android:text="Train:"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    />
                <TextView android:id="@+id/txtTicketNumber" android:text="Ticket:"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
                <TextView android:id="@+id/txtSeatNumber" android:text="Seat:"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
                <TextView android:id="@+id/txtCoachNumber" android:text="Coach:"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
                <TextView android:id="@+id/txtPhone" android:text="Phone:"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>
                <TextView android:id="@+id/txtMealStation" android:text="Station:"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>








