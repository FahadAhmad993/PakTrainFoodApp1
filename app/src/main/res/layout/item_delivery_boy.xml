<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp"
    android:backgroundTint="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Left section: Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Name -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_profile"
                    android:layout_marginEnd="6dp"
                    app:tint="@color/purple_light" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fahad Ahmad"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black" />
            </LinearLayout>

            <!-- Phone -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_swap"
                    android:layout_marginEnd="6dp"
                    app:tint="@color/purple_light" />

                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="03001234567"
                    android:textSize="15sp"
                    android:textColor="@android:color/black" />
            </LinearLayout>

            <!-- Email -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_pending"
                    android:layout_marginEnd="6dp"
                    app:tint="@color/purple_light" />

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="fa9293493@gmail.com"
                    android:textSize="15sp"
                    android:textColor="@android:color/black" />
            </LinearLayout>

            <!-- Delivery Status -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_browse_menu"
                    android:layout_marginEnd="6dp"
                    app:tint="@color/purple_light" />

                <TextView
                    android:id="@+id/txtDeliveryOnlineStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available"
                    android:textSize="15sp"
                    android:textColor="@color/purple_light" />
            </LinearLayout>

            <!-- Rating -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:rating="4"
                    android:stepSize="1"
                    android:scaleX="0.9"
                    android:scaleY="0.9"
                    style="?android:attr/ratingBarStyleSmall" />
            </LinearLayout>

            <!-- Button -->
            <Button
                android:id="@+id/btnDeliverOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deliver Order"
                android:paddingHorizontal="20dp"
                android:paddingVertical="6dp"
                android:backgroundTint="@color/purple_light"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- Right side: Image -->
        <ImageView
            android:id="@+id/imgDeliveryBoy"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginStart="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_food_placeholder"
            android:background="@drawable/selected_circle_bg"
            android:padding="2dp" />
    </LinearLayout>

</androidx.cardview.widget.CardView>



