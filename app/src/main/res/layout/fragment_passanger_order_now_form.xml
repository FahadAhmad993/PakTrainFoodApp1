<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="14dp"
    android:background="@android:color/transparent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="8dp"
        android:layout_margin="8dp"
        android:backgroundTint="@android:color/white">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/imgFood"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_food_placeholder"
                android:contentDescription="food image"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Food Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/txtPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rs. 0"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtRest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Restaurant"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:textSize="13sp"
                android:textColor="#666666" />

            <!-- inputs -->
            <EditText
                android:id="@+id/edtTicket"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ticket Number"
                android:inputType="text"
                android:layout_marginTop="12dp"
                android:padding="10dp"
                android:background="@drawable/edittext_bg" />

            <EditText
                android:id="@+id/edtCoach"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Coach Number"
                android:inputType="text"
                android:layout_marginTop="8dp"
                android:padding="10dp"
                android:background="@drawable/edittext_bg" />

            <EditText
                android:id="@+id/edtSeat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Seat Number"
                android:inputType="text"
                android:layout_marginTop="8dp"
                android:padding="10dp"
                android:background="@drawable/edittext_bg" />

            <EditText
                android:id="@+id/edtTrain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Train Name"
                android:inputType="text"
                android:layout_marginTop="8dp"
                android:padding="10dp"
                android:background="@drawable/edittext_bg" />

            <EditText
                android:id="@+id/edtPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone Number"
                android:inputType="phone"
                android:layout_marginTop="8dp"
                android:padding="10dp"
                android:background="@drawable/edittext_bg" />

            <Button
                android:id="@+id/btnOrderNow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Order Now"
                android:textAllCaps="false"
                android:layout_marginTop="14dp"
                android:backgroundTint="#FF5722"
                android:textColor="#FFFFFF"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textAllCaps="false"
                android:layout_marginTop="8dp"
                android:backgroundTint="#9E9E9E"
                android:textColor="#FFFFFF"
                android:padding="12dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</ScrollView>
