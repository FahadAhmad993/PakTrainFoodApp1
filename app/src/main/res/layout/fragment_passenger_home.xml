<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7"
    android:padding="0dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top Banner With Text Overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:padding="0dp">

            <ImageView
                android:id="@+id/image_station_top"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/station3"
                android:background="@drawable/top_rounded_image"
                android:clipToOutline="true" />

            <!-- Overlay Text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="20dp"
                android:orientation="vertical"
                android:gravity="bottom">

                <TextView
                    android:text="Welcome, Passenger"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content" />

                <TextView
                    android:text="Order fresh meals for your journey"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textColor="#EEEEEE"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

        </FrameLayout>


        <!-- White Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/white_card"
            android:elevation="4dp">

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="Journey Route"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333" />

            <!-- From Station -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="From"
                android:layout_marginTop="12dp">

                <AutoCompleteTextView
                    android:id="@+id/actv_from"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Swap Button -->
            <ImageButton
                android:id="@+id/btn_swap"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginTop="10dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/ic_swap"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#555555" />

            <!-- To -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="To"
                android:layout_marginTop="10dp">

                <AutoCompleteTextView
                    android:id="@+id/actv_to"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Train Select -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select Train"
                android:layout_marginTop="10dp">

                <AutoCompleteTextView
                    android:id="@+id/actv_train"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Meal Station -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Meal Station"
                android:layout_marginTop="10dp">

                <AutoCompleteTextView
                    android:id="@+id/actv_meal_station"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Route Preview -->
            <TextView
                android:id="@+id/tv_route_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Route preview will show here"
                android:textColor="#444444"
                android:textSize="14sp"
                android:padding="12dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/light_grey_box" />

            <!-- Next Button -->
            <Button
                android:id="@+id/btn_next_to_restaurants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Find Restaurants"
                android:textAllCaps="false"
                android:backgroundTint="#4A4A55"
                android:textColor="#FFFFFF"
                android:layout_marginTop="18dp"
                android:padding="12dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>





